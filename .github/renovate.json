{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    },
    {
      "matchPackageNames": ["python"],
      "enabled": false
    }
  ],
  "schedule": ["before 9am on Monday"],
  "prHourlyLimit": 5,
  "prConcurrentLimit": 10
}
