# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── Database ───────────────────────────────────────────────────────────────────
# VS Code / make dev: uses localhost (direct connection)
# Docker compose: overrides with postgresql+asyncpg://postgres:postgres@postgres:5432/...
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/gunther_api_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis ──────────────────────────────────────────────────────────────────────
# VS Code / make dev: uses localhost
# Docker compose: overrides with redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# ── Sentry ─────────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── OpenTelemetry ──────────────────────────────────────────────────────────────
# VS Code / make dev: Alloy must be running (standalone mode or platform)
# Docker compose: overrides with http://alloy:4317
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=gunther_api
OTEL_SERVICE_VERSION=0.1.0
OTEL_ENVIRONMENT=development

# ── JWT ─────────────────────────────────────────────────────────────────────────
# Generated by `octopus new` — never commit the real value
JWT_SECRET_KEY=REPLACE_ME_WITH_GENERATED_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Octopus ────────────────────────────────────────────────────────────────────
OCTOPUS_API_URL=http://localhost:8888

# ── Authentik dev bypass (local development only — never set in production) ────
# DEV_USER_UID=local-dev-user
# DEV_USER_USERNAME=dev
# DEV_USER_EMAIL=dev@localhost
# DEV_USER_GROUPS=developers|admins
