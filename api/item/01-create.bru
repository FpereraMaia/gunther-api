meta {
  name: Create Item
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/items/
  body: json
  auth: bearer
}

auth:bearer {
  token: {{authToken}}
}

body:json {
  {
    "name": "My New Item",
    "description": "A description for this item"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("itemId", res.body.id);
  }
}
