{
  "name": "gunther_api",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "runArgs": ["--network=octopus-network"],
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "mounts": [
    "source=/run/user/1000/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance",
        "ms-python.mypy-type-checker",
        "charliermarsh.ruff",
        "ms-azuretools.vscode-docker",
        "humao.rest-client",
        "tamasfe.even-better-toml"
      ],
      "settings": {
        "python.defaultInterpreterPath": "${containerWorkspaceFolder}/.venv/bin/python"
      }
    }
  },
  "remoteUser": "root",
  "postCreateCommand": "pip install uv && uv sync && uv run pre-commit install && cp .github/hooks/post-merge .git/hooks/post-merge && chmod +x .git/hooks/post-merge",
  "forwardPorts": [8000, 5678],
  "remoteEnv": {
    "PYTHONPATH": "${containerWorkspaceFolder}/src"
  }
}
